<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contribution Manager</title>
<script src="https://unpkg.com/react@18/umd/react.development.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.tailwindcss.com"></script>
<style>
@media print {
  body * { visibility: hidden; }
  #print-area, #print-area * { visibility: visible; }
  #print-area { position: absolute; left: 0; top: 0; width: 100%; }
}
</style>
</head>
<body class="bg-gradient-to-br from-slate-900 to-slate-800 min-h-screen text-slate-100">
<div id="root"></div>

<script type="text/babel">
const {useState, useEffect, useRef} = React;

const DB_KEY = 'cm_db_v1';

function loadDB() {
  const data = localStorage.getItem(DB_KEY);
  if (data) return JSON.parse(data);
  return {
    users: [
      {username: 'admin', password: 'admin123', role: 'admin'},
      {username: 'user', password: 'user123', role: 'user'}
    ],
    members: [],
    transactions: [],
    currency: '₦',
    poolAdjustments: 0
  };
}

function saveDB(db) {
  localStorage.setItem(DB_KEY, JSON.stringify(db));
}

function App() {
  const [db, setDB] = useState(loadDB());
  const [user, setUser] = useState(null);
  const [page, setPage] = useState('login');
  const [printData, setPrintData] = useState(null);
  const [showGlobalCashout, setShowGlobalCashout] = useState(false);
  const printRef = useRef();

  useEffect(() => {
    saveDB(db);
  }, [db]);

  const login = (username, password) => {
    const found = db.users.find(u => u.username === username && u.password === password);
    if (found) {
      setUser(found);
      setPage('dashboard');
    } else {
      alert('Invalid credentials');
    }
  };

  const logout = () => {
    setUser(null);
    setPage('login');
  };

  const setCurrency = (symbol) => {
    setDB({...db, currency: symbol});
  };

  const addMember = (member) => {
    const newMember = {...member, id: Date.now(), balance: 0};
    setDB({...db, members: [...db.members, newMember]});
  };

  const updateMember = (id, data) => {
    setDB({
     ...db,
      members: db.members.map(m => m.id === id? {...m,...data} : m)
    });
  };

  const addContribution = (memberId, amount, note, type = 'deposit') => {
    const member = db.members.find(m => m.id === memberId);
    if (!member) return;

    const numAmount = parseFloat(amount);
    if (type === 'withdrawal' && member.balance < numAmount) {
      alert('Error: Insufficient balance for withdrawal.');
      return false;
    }

    const txn = {
      id: Date.now(),
      memberId,
      memberName: member.name,
      amount: numAmount,
      type,
      date: new Date().toISOString(),
      note,
      operator: user.username
    };

    const balanceModifier = type === 'withdrawal'? -numAmount : numAmount;

    setDB({
     ...db,
      members: db.members.map(m =>
        m.id === memberId? {...m, balance: m.balance + balanceModifier} : m
      ),
      transactions: [txn,...db.transactions]
    });
    return true;
  };

  const addGlobalPoolCashout = (amount, note) => {
    const numAmount = parseFloat(amount);
    const calculatedTotalPool = db.members.reduce((sum, m) => sum + m.balance, 0) - (db.poolAdjustments || 0);

    if (numAmount > calculatedTotalPool) {
      alert('Error: Cash out amount exceeds total available pool liquidity.');
      return false;
    }

    const txn = {
      id: Date.now(),
      memberId: 'POOL_SYSTEM',
      memberName: '🚨 Pool Global Cashout',
      amount: numAmount,
      type: 'pool_cashout',
      date: new Date().toISOString(),
      note,
      operator: user.username
    };

    setDB({
     ...db,
      poolAdjustments: (db.poolAdjustments || 0) + numAmount,
      transactions: [txn,...db.transactions]
    });
    return true;
  };

  const downloadBackup = () => {
    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(db, null, 2));
    const downloadAnchor = document.createElement('a');
    downloadAnchor.setAttribute("href", dataStr);
    downloadAnchor.setAttribute("download", `contribution_manager_backup_${new Date().toISOString().split('T')[0]}.json`);
    document.body.appendChild(downloadAnchor);
    downloadAnchor.click();
    downloadAnchor.remove();
  };

  const totalPool = db.members.reduce((sum, m) => sum + m.balance, 0) - (db.poolAdjustments || 0);
  const isAdmin = user?.role === 'admin';
  const currencySymbol = db.currency || '₦';

  return (
    <div className="min-h-screen p-4">
      {page === 'login' && <LoginPage onLogin={login} />}

      {user && (
        <div className="max-w-7xl mx-auto bg-slate-800 rounded-2xl shadow-2xl p-6">
          <Header
            user={user}
            onLogout={logout}
            setPage={setPage}
            isAdmin={isAdmin}
            currency={currencySymbol}
            onCurrencyChange={setCurrency}
          />

          {page === 'dashboard' && <Dashboard
            members={db.members}
            transactions={db.transactions}
            totalPool={totalPool}
            isAdmin={isAdmin}
            setPage={setPage}
            currency={currencySymbol}
            onBackup={downloadBackup}
            onOpenGlobalCashout={() => setShowGlobalCashout(true)}
          />}

          {page === 'members' && <MembersPage
            members={db.members}
            isAdmin={isAdmin}
            currency={currencySymbol}
            onAddMember={addMember}
            onUpdateMember={updateMember}
            onAddContribution={addContribution}
            onPrintSlip={setPrintData}
          />}

          {page === 'search' && <SearchPage
            members={db.members}
            currency={currencySymbol}
            onPrintSlip={setPrintData}
          />}
        </div>
      )}

      {showGlobalCashout && (
        <GlobalCashoutModal
          totalPool={totalPool}
          currency={currencySymbol}
          onSubmit={addGlobalPoolCashout}
          onClose={() => setShowGlobalCashout(false)}
        />
      )}

      {printData && (
        <div id="print-area" ref={printRef}>
          <PrintSlip data={printData} currency={currencySymbol} onClose={() => setPrintData(null)} />
        </div>
      )}
    </div>
  );
}

function LoginPage({onLogin}) {
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');

  return (
    <div className="flex items-center justify-center min-h-screen">
      <div className="bg-slate-800 p-8 rounded-2xl shadow-2xl w-full max-w-md">
        <div className="text-center mb-6">
          <div className="text-5xl mb-3">💰</div>
          <h1 className="text-2xl font-bold">Contribution Manager</h1>
          <p className="text-slate-400">Secure Role-Based Access</p>
        </div>
        <div className="space-y-4">
          <input
            type="text"
            placeholder="Username"
            value={username}
            onChange={e => setUsername(e.target.value)}
            className="w-full p-3 rounded-lg bg-slate-700 border-slate-600 focus:border-blue-500 outline-none"
          />
          <input
            type="password"
            placeholder="Password"
            value={password}
            onChange={e => setPassword(e.target.value)}
            className="w-full p-3 rounded-lg bg-slate-700 border-slate-600 focus:border-blue-500 outline-none"
          />
          <button
            onClick={() => onLogin(username, password)}
            className="w-full bg-blue-600 hover:bg-blue-700 p-3 rounded-lg font-semibold transition"
          >
            Login
          </button>
        </div>
        <p className="text-xs text-slate-500 mt-4 text-center">
          Admin: admin/admin123 | User: user/user123
        </p>
      </div>
    </div>
  );
}

function Header({user, onLogout, setPage, isAdmin, currency, onCurrencyChange}) {
  return (
    <div className="flex flex-col md:flex-row gap-4 justify-between items-center mb-6 pb-4 border-b border-slate-700">
      <div className="flex items-center gap-4">
        <h2 className="text-xl font-bold">{user.username} <span className="text-sm text-slate-400">({user.role})</span></h2>
        {isAdmin && (
          <div className="flex bg-slate-700 p-1 rounded-lg border-slate-600 text-xs">
            <button onClick={() => onCurrencyChange('₦')} className={`px-2 py-1 rounded ${currency === '₦'? 'bg-blue-600 text-white font-bold' : 'text-slate-400'}`}>₦ NGN</button>
            <button onClick={() => onCurrencyChange('$')} className={`px-2 py-1 rounded ${currency === '$'? 'bg-blue-600 text-white font-bold' : 'text-slate-400'}`}>$ USD</button>
          </div>
        )}
      </div>
      <div className="flex flex-wrap gap-2">
        <button onClick={() => setPage('dashboard')} className="px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg">Dashboard</button>
        <button onClick={() => setPage('members')} className="px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg">Members</button>
        <button onClick={() => setPage('search')} className="px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg">Search</button>
        <button onClick={onLogout} className="px-4 py-2 bg-red-600 hover:bg-red-700 rounded-lg">Logout</button>
      </div>
    </div>
  );
}

function Dashboard({members, transactions, totalPool, isAdmin, setPage, currency, onBackup, onOpenGlobalCashout}) {
  return (
    <div>
      <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <h1 className="text-3xl font-bold">Analytics Dashboard</h1>
        <div className="flex gap-2 w-full sm:w-auto">
          {isAdmin && (
            <>
              <button onClick={onOpenGlobalCashout} className="bg-red-600 hover:bg-red-700 text-xs px-3 py-2 rounded-lg flex items-center gap-1 transition font-semibold">
                📤 Pool Cash Out
              </button>
              <button onClick={onBackup} className="bg-slate-700 hover:bg-slate-600 text-xs px-3 py-2 rounded-lg flex items-center gap-1 border-slate-600 transition">
                💾 Backup
              </button>
            </>
          )}
        </div>
      </div>
      {isAdmin && (
        <>
          <div className="grid md:grid-cols-3 gap-4 mb-6">
            <div className="bg-gradient-to-br from-blue-600 to-blue-700 p-6 rounded-xl relative overflow-hidden group">
              <p className="text-sm opacity-80">Total Pool Liquidity</p>
              <h3 className="text-3xl font-bold">{currency}{totalPool.toLocaleString(undefined, {minimumFractionDigits: 2})}</h3>
            </div>
            <div className="bg-gradient-to-br from-green-600 to-green-700 p-6 rounded-xl">
              <p className="text-sm opacity-80">Registered Contributors</p>
              <h3 className="text-3xl font-bold">{members.length}</h3>
            </div>
            <div className="bg-gradient-to-br from-purple-600 to-purple-700 p-6 rounded-xl">
              <p className="text-sm opacity-80">Total Transactions</p>
              <h3 className="text-3xl font-bold">{transactions.length}</h3>
            </div>
          </div>

          <h3 className="text-xl font-semibold mb-3">All Recorded Transactions</h3>
          <div className="bg-slate-700 rounded-xl overflow-hidden border-slate-600 shadow-inner">
            <div className="max-h-96 overflow-y-auto">
              <table className="w-full text-sm relative">
                <thead className="bg-slate-900 sticky top-0 z-10 shadow">
                  <tr>
                    <th className="p-3 text-left">Date</th>
                    <th className="p-3 text-left">Member/Source</th>
                    <th className="p-3 text-left">Type</th>
                    <th className="p-3 text-left">Amount</th>
                    <th className="p-3 text-left">Operator</th>
                    <th className="p-3 text-left">Note</th>
                  </tr>
                </thead>
                <tbody>
                  {transactions.length === 0? (
                    <tr>
                      <td colSpan="6" className="p-8 text-center text-slate-400">No transactions recorded yet.</td>
                    </tr>
                  ) : (
                    transactions.map(t => (
                      <tr key={t.id} className="border-t border-slate-600/50 hover:bg-slate-600/30 transition">
                        <td className="p-3 whitespace-nowrap">{new Date(t.date).toLocaleString()}</td>
                        <td className="p-3 font-medium">{t.memberName}</td>
                        <td className="p-3">
                          <span className={`px-2 py-0.5 rounded text-xs uppercase font-bold
                            ${t.type === 'withdrawal'? 'bg-red-900/50 text-red-400' :
                              t.type === 'pool_cashout'? 'bg-amber-950 text-amber-400 border border-amber-600' :
                              'bg-green-900/50 text-green-400'}`}>
                            {t.type === 'pool_cashout'? 'pool payout' : (t.type || 'deposit')}
                          </span>
                        </td>
                        <td className={`p-3 font-semibold ${t.type === 'withdrawal' || t.type === 'pool_cashout'? 'text-red-400' : 'text-green-400'}`}>
                          {t.type === 'withdrawal' || t.type === 'pool_cashout'? '-' : '+'}{currency}{t.amount.toLocaleString(undefined, {minimumFractionDigits: 2})}
                        </td>
                        <td className="p-3 text-slate-300">{t.operator}</td>
                        <td className="p-3 max-w-xs truncate text-slate-400" title={t.note}>{t.note || '-'}</td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>
          </div>
        </>
      )}
      {!isAdmin && <p className="text-slate-400">You have read-only access. Go to Search to find members.</p>}
    </div>
  );
}

function MembersPage({members, isAdmin, currency, onAddMember, onUpdateMember, onAddContribution, onPrintSlip}) {
  const [showForm, setShowForm] = useState(false);
  const [editing, setEditing] = useState(null);
  const [fundingAction, setFundingAction] = useState(null);

  return (
    <div>
      <div className="flex justify-between items-center mb-6">
        <h1 className="text-3xl font-bold">Member Registry</h1>
        {isAdmin && <button onClick={() => setShowForm(true)} className="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg font-semibold">+ Add Member</button>}
      </div>

      {showForm && <MemberForm onSubmit={onAddMember} onClose={() => setShowForm(false)} />}
      {editing && <MemberForm member={editing} onSubmit={(data) => {onUpdateMember(editing.id, data); setEditing(null);}} onClose={() => setEditing(null)} />}
      {fundingAction && <ContributionModal member={fundingAction.member} type={fundingAction.type} onSubmit={onAddContribution} onClose={() => setFundingAction(null)} />}

      <div className="bg-slate-700 rounded-xl overflow-x-auto">
        <table className="w-full text-sm">
          <thead className="bg-slate-900">
            <tr>
              <th className="p-3 text-left">Photo</th>
              <th className="p-3 text-left">Name</th>
              <th className="p-3 text-left">GSM</th>
              <th className="p-3 text-left">Email</th>
              <th className="p-3 text-left">Balance</th>
              <th className="p-3 text-left">Actions</th>
            </tr>
          </thead>
          <tbody>
            {members.map(m => (
              <tr key={m.id} className="border-t border-slate-600">
                <td className="p-3">
                  {m.photo? <img src={m.photo} key={m.id} className="w-10 h-10 rounded-full object-cover border-slate-500" /> : '👤'}
                </td>
                <td className="p-3 font-semibold">{m.name}</td>
                <td className="p-3">{m.gsm}</td>
                <td className="p-3 text-slate-300">{m.email || '-'}</td>
                <td className="p-3 font-bold text-green-400">{currency}{m.balance.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                <td className="p-3 space-x-1 space-y-1">
                  {isAdmin && <button onClick={() => setFundingAction({member: m, type: 'deposit'})} className="bg-green-600 hover:bg-green-700 px-2 py-1 rounded text-xs font-semibold">+ Money</button>}
                  {isAdmin && <button onClick={() => setFundingAction({member: m, type: 'withdrawal'})} className="bg-red-600 hover:bg-red-700 px-2 py-1 rounded text-xs font-semibold">- Cash out</button>}
                  {isAdmin && <button onClick={() => setEditing(m)} className="bg-blue-600 hover:bg-blue-700 px-2 py-1 rounded text-xs">Edit</button>}
                  <button onClick={() => onPrintSlip(m)} className="bg-slate-600 hover:bg-slate-500 px-2 py-1 rounded text-xs">Print Slip</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

function MemberForm({member, onSubmit, onClose}) {
  const [form, setForm] = useState(member || {name:'', email:'', gsm:'', gender:'', photo:'', note:''});
  const fileInputRef = useRef();

  const handleSubmit = () => {
    if (!form.name ||!form.gsm) return alert('Name and GSM required');
    onSubmit(form);
    onClose();
  };

  const handleFileChange = (e) => {
    const file = e.target.files[0];
    if (file) {
      if (file.size > 2 * 1024 * 1024) {
        alert("Image is too large. Please select an image under 2MB.");
        return;
      }
      const reader = new FileReader();
      reader.onloadend = () => {
        setForm({...form, photo: reader.result});
      };
      reader.readAsDataURL(file);
    }
  };

  return (
    <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
      <div className="bg-slate-800 p-6 rounded-xl w-full max-w-lg max-h-[90vh] overflow-y-auto border-slate-700 shadow-2xl">
        <h3 className="text-xl font-bold mb-4 text-blue-400">{member? 'Edit Member Details' : 'Register New Member'}</h3>
        <div className="space-y-4">
          <div>
            <label className="text-xs text-slate-400 block mb-1 font-medium">Full Legal Name *</label>
            <input placeholder="John Doe" value={form.name} onChange={e => setForm({...form, name:e.target.value})} className="w-full p-2.5 rounded bg-slate-700 border-slate-600 outline-none focus:border-blue-500" />
          </div>
          <div>
            <label className="text-xs text-slate-400 block mb-1 font-medium">Email Address</label>
            <input type="email" placeholder="example@domain.com" value={form.email} onChange={e => setForm({...form, email:e.target.value})} className="w-full p-2.5 rounded bg-slate-700 border-slate-600 outline-none focus:border-blue-500" />
          </div>
          <div>
            <label className="text-xs text-slate-400 block mb-1 font-medium">GSM Phone Number *</label>
            <input type="tel" placeholder="08012345678" value={form.gsm} onChange={e => setForm({...form, gsm:e.target.value})} className="w-full p-2.5 rounded bg-slate-700 border-slate-600 outline-none focus:border-blue-500" />
          </div>
          <div>
            <label className="text-xs text-slate-400 block mb-1 font-medium">Gender</label>
            <select value={form.gender} onChange={e => setForm({...form, gender:e.target.value})} className="w-full p-2.5 rounded bg-slate-700 border-slate-600 outline-none focus:border-blue-500">
              <option value="">Select Gender</option>
              <option>Male</option><option>Female</option><option>Other</option>
            </select>
          </div>

          <div className="bg-slate-700/50 p-3 rounded-lg border-dashed border-slate-600">
            <label className="text-xs text-slate-300 block mb-2 font-medium">Profile Image Selection</label>
            <div className="flex items-center gap-4">
              <div className="w-14 h-14 bg-slate-700 rounded-full flex items-center justify-center overflow-hidden border-slate-500 shrink-0">
                {form.photo? <img src={form.photo} className="w-full h-full object-cover" /> : <span className="text-xl">👤</span>}
              </div>
              <div className="flex-1 space-y-1">
                <input
                  type="file"
                  accept="image/*"
                  capture="user"
                  ref={fileInputRef}
                  onChange={handleFileChange}
                  className="hidden"
                />
                <div className="flex gap-2">
                  <button
                    type="button"
                    onClick={() => fileInputRef.current.click()}
                    className="bg-blue-600 hover:bg-blue-700 text-xs py-2 px-3 rounded font-medium transition flex-1"
                  >
                    📸 Upload or Take Photo
                  </button>
                  {form.photo && (
                    <button
                      type="button"
                      onClick={() => setForm({...form, photo: ''})}
                      className="bg-slate-600 hover:bg-slate-500 text-xs py-2 px-2 rounded text-red-400 transition"
                    >
                      Clear
                    </button>
                  )}
                </div>
                <p className="text-[10px] text-slate-400">Supports direct mobile camera capture or photo gallery selections.</p>
              </div>
            </div>
          </div>

          <div>
            <label className="text-xs text-slate-400 block mb-1 font-medium">System Notes</label>
            <textarea placeholder="Write remarks or notes..." value={form.note} onChange={e => setForm({...form, note:e.target.value})} className="w-full p-2.5 rounded bg-slate-700 border-slate-600 outline-none focus:border-blue-500" rows="2"></textarea>
          </div>
        </div>
        <div className="flex gap-2 mt-5">
          <button onClick={handleSubmit} className="flex-1 bg-green-600 hover:bg-green-700 p-2.5 rounded font-semibold transition shadow-md">Save Member</button>
          <button onClick={onClose} className="flex-1 bg-slate-600 hover:bg-slate-700 p-2.5 rounded transition">Cancel</button>
        </div>
      </div>
    </div>
  );
}

function ContributionModal({member, type, onSubmit, onClose}) {
  const [amount, setAmount] = useState('');
  const [note, setNote] = useState('');

  const isWithdrawal = type === 'withdrawal';

  const handleSubmit = () => {
    if (!amount || amount <= 0) return alert('Enter valid amount');
    const success = onSubmit(member.id, amount, note, type);
    if (success!== false) onClose();
  };

  return (
    <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
      <div className="bg-slate-800 p-6 rounded-xl w-full max-w-sm border-slate-700 shadow-2xl">
        <h3 className={`text-xl font-bold mb-1 ${isWithdrawal? 'text-red-400' : 'text-green-400'}`}>
          {isWithdrawal? 'Record Cash Withdrawal' : 'Add Contribution'}
        </h3>
        <p className="text-slate-400 mb-4">{member.name}</p>

        {isWithdrawal && (
          <div className="mb-3 p-2 bg-slate-700 border-l-4 border-red-500 rounded text-xs text-slate-300">
            Available Balance: <strong>₦{member.balance.toFixed(2)}</strong>
          </div>
        )}

        <input type="number" placeholder="Amount" value={amount} onChange={e => setAmount(e.target.value)} className="w-full p-2 rounded bg-slate-700 border-slate-600 mb-3 outline-none focus:border-blue-500" />
        <input placeholder="Note" value={note} onChange={e => setNote(e.target.value)} className="w-full p-2 rounded bg-slate-700 border-slate-600 mb-4 outline-none focus:border-blue-500" />
        <div className="flex gap-2">
          <button onClick={handleSubmit} className={`flex-1 p-2 rounded font-semibold transition ${isWithdrawal? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700'}`}>
            {isWithdrawal? 'Withdraw' : 'Add'}
          </button>
          <button onClick={onClose} className="flex-1 bg-slate-600 hover:bg-slate-700 p-2 rounded transition">Cancel</button>
        </div>
      </div>
    </div>
  );
}

function GlobalCashoutModal({totalPool, currency, onSubmit, onClose}) {
  const [amount, setAmount] = useState('');
  const [note, setNote] = useState('');

  const handleGlobalSubmit = () => {
    if (!amount || amount <= 0) return alert('Enter a valid positive amount.');
    if (!note) return alert('Please enter a note explaining this pool payout.');
    const success = onSubmit(amount, note);
    if (success!== false) onClose();
  };

  return (
    <div className="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 backdrop-blur-sm">
      <div className="bg-slate-800 p-6 rounded-xl w-full max-w-sm border-red-500/30 shadow-2xl">
        <h3 className="text-xl font-bold mb-1 text-red-400">📤 Total Pool Cash Out</h3>
        <p className="text-slate-400 text-xs mb-3">Deduct liquidity directly out of the accumulated system totals.</p>

        <div className="mb-4 p-2.5 bg-slate-700 border-l-4 border-amber-500 rounded text-xs text-slate-200">
          Max Available Pool: <strong className="text-green-400">{currency}{totalPool.toLocaleString(undefined, {minimumFractionDigits: 2})}</strong>
        </div>

        <div className="space-y-3">
          <input
            type="number"
            placeholder="Amount to Cash Out"
            value={amount}
            onChange={e => setAmount(e.target.value)}
            className="w-full p-2.5 rounded bg-slate-700 border-slate-600 outline-none focus:border-red-500"
          />
          <input
            placeholder="Reason (e.g. Bank Payout, Management Expense)"
            value={note}
            onChange={e => setNote(e.target.value)}
            className="w-full p-2.5 rounded bg-slate-700 border-slate-600 outline-none focus:border-red-500"
          />
        </div>

        <div className="flex gap-2 mt-5">
          <button onClick={handleGlobalSubmit} className="flex-1 bg-red-600 hover:bg-red-700 p-2.5 rounded font-semibold transition">
            Confirm Cashout
          </button>
          <button onClick={onClose} className="flex-1 bg-slate-600 hover:bg-slate-700 p-2.5 rounded transition">
            Cancel
          </button>
        </div>
      </div>
    </div>
  );
}

function SearchPage({members, currency, onPrintSlip}) {
  const [query, setQuery] = useState('');
  const filtered = members.filter(m =>
    m.name.toLowerCase().includes(query.toLowerCase()) ||
    m.gsm.includes(query)
  );

  return (
    <div className="min-h-[400px]">
      <h1 className="text-3xl font-bold mb-6">Search & Verify</h1>
      <input
        type="text"
        placeholder="Type name or GSM to search..."
        value={query}
        onChange={e => setQuery(e.target.value)}
        className="w-full p-3 rounded-lg bg-slate-700 border-slate-600 mb-4"
      />
      <div className="space-y-3">
        {filtered.map(m => (
          <div key={m.id} className="bg-slate-700 p-4 rounded-xl flex justify-between items-center">
            <div>
              <h3 className="font-bold">{m.name}</h3>
              <p className="text-sm text-slate-400">{m.gsm} | Balance: <span className="text-green-400 font-semibold">{currency}{m.balance.toLocaleString(undefined, {minimumFractionDigits: 2})}</span></p>
            </div>
            <button onClick={() => onPrintSlip(m)} className="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg">Print Slip</button>
          </div>
        ))}
      </div>
    </div>
  );
}

function PrintSlip({data, currency, onClose}) {
  return (
    <div className="bg-white text-black p-8 max-w-2xl mx-auto">
      <div className="text-center border-b-2 border-blue-800 pb-4 mb-6">
        <h1 className="text-2xl font-bold text-blue-800">Contribution Manager</h1>
        <p>Official Verification Receipt</p>
      </div>
      <div className="flex gap-6">
        <div>
          {data.photo? <img src={data.photo} className="w-32 h-32 rounded-full object-cover border-4 border-blue-800" /> :
          <div className="w-32 h-32 rounded-full bg-slate-200 flex items-center justify-center">No Photo</div>}
        </div>
        <div className="flex-1">
          <div className="space-y-3">
            <div><strong>Name:</strong> {data.name}</div>
            <div><strong>GSM:</strong> {data.gsm}</div>
            <div><strong>Email:</strong> {data.email || '-'}</div>
            <div><strong>Gender:</strong> {data.gender || '-'}</div>
            <div className="text-2xl font-bold text-green-700 mt-4">Total Balance: {currency}{data.balance.toLocaleString(undefined, {minimumFractionDigits: 2})}</div>
          </div>
        </div>
      </div>
      <div className="mt-12 flex justify-between">
        <div className="text-center">
          <div className="border-t border-black w-48 mt-12"></div>
          <p>Operator Signature</p>
        </div>
        <div className="text-center">
          <div className="border-t border-black w-48 mt-12"></div>
          <p>Contributor Signature</p>
        </div>
      </div>
      <div className="text-center mt-8 text-xs text-slate-500">
        Generated: {new Date().toLocaleString()}
      </div>
      <button onClick={() => {window.print(); onClose();}} className="mt-6 w-full bg-blue-600 text-white p-2 rounded print:hidden">Print</button>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>